# Copy to .env and fill in. Do NOT commit .env.
OPENAI_API_KEY=sk-...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
# Locally: run `stripe listen --forward-to localhost:5000/webhooks/stripe`
# and paste the `whsec_...` the CLI prints. On Render, get this from the
# Stripe Dashboard → Developers → Webhooks → your endpoint → Signing secret.
STRIPE_WEBHOOK_SECRET=whsec_...
FLASK_SECRET_KEY=change-me-to-a-long-random-string

# Printify fulfilment + admin diagnostic route.
PRINTIFY_API_KEY=
ADMIN_TOKEN=change-me-to-any-random-string-you-want
